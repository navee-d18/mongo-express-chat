<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Write new chat</title>
</head>
<body>
    <h2>Write New Chat</h2>
    <form method="post" action="/chats">
        <input type="text" placeholder="Who are you?" name="from"><br><br>
        <textarea name="msg" placeholder="Write Your message here..." cols="30" rows="10"></textarea> <br><br>
        <input type="text" placeholder="To Reciever" name="to"><br><br>
        <button>Create chat</button>
    </form>
</body>
</html>